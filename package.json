  "dependenciesMeta": {
    "esbuild": {
      "built": true
    },
    "puppeteer": {
      "built": true
    }
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "webdriver-manager"
    ],
    "overrides": {
